TELEGRAM_BOT_TOKEN=put-your-token-here
CHECK_URL=https://kino.pub/
CHECK_INTERVAL_SECONDS=60

# Optional: browser session cookie for checking the authenticated app instead of only the public login page.
# CHECK_COOKIE=PHPSESSID=...; _csrf=...

# Optional: tune status stability.
# SLOW_RESPONSE_SECONDS=10
# RECOVERY_CONFIRMATION_CHECKS=3

# Optional: comma-separated chat IDs to notify before anyone runs /start or /status.
# TELEGRAM_CHAT_IDS=123456789,-1001234567890
